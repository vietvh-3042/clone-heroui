{
  "name": "heroui",
  "private": true,
  "version": "2.0.0",
  "license": "MIT",
  "author": "HeroUI <support@heroui.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/heroui-inc/heroui"
  },
  "scripts": {
    "dev": "pnpm sb",
    "build": "turbo build --filter='!@heroui/docs' --filter='!@heroui/storybook' --filter='!@heroui/stories-utils' --filter='!@heroui/test-utils'",
    "sb": "pnpm --filter @heroui/storybook dev",
    "lint": "pnpm lint:pkg && pnpm lint:docs",
    "lint:pkg": "eslint -c .eslintrc.json ./packages/**/*.{ts,tsx}",
    "lint:docs": "eslint -c .eslintrc.json ./apps/docs/**/*.{ts,tsx,js,jsx}",
    "lint:fix": "eslint --fix -c .eslintrc.json ./packages/**/*.{ts,tsx}",
    "lint:docs-fix": "eslint --fix -c .eslintrc.json ./apps/docs/**/*.{ts,tsx,js,jsx}",
    "postinstall": "husky install && pnpm --filter @heroui/theme build"
  },
